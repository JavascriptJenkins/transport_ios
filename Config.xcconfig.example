// Copy this file to Config.xcconfig and fill in real values.
// Config.xcconfig is gitignored — never commit real keys.
//
// NOTE: xcconfig treats `//` as a comment. For any URL value, use $()
// to break up the double-slash, e.g.  https:/$()/host.example.com

TRANSPORT_API_KEY = your_api_key_here
TRANSPORT_BASE_URL = https:/$()/haven.bunepos.com
